{
  "name": "chatrix",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@types/bun": "^1.3.13"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@google/genai": "^1.50.1",
    "@google/generative-ai": "^0.24.1",
    "better-auth": "^1.6.2",
    "bun.lock": "^0.0.0",
    "jsonwebtoken": "^9.0.3"
  },
  "scripts": {
    "dev": "bun --watch src/server.ts",
    "start": "bun src/server.ts",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "check": "bunx tsc --noEmit && biome lint src",
    "check:full": "biome check .",
    "fix": "biome check . --apply"
  }
}
